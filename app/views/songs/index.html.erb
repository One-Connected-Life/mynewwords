<% content_for :title, "Songs" %>

<header class="mb-6">
  <%= link_to "← Add", add_path, class: "text-xs text-gray-500 hover:underline dark:text-gray-400" %>
  <h1 class="mt-2 text-2xl font-semibold tracking-tight">🎵 Learn from a song</h1>
  <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
    A beloved Dutch classic becomes a deck — its words, verb conjugations and example
    sentences. Listen to the original, then drill it.
  </p>
</header>

<ul class="divide-y divide-gray-100 overflow-hidden rounded-xl border border-gray-200 dark:divide-gray-800 dark:border-gray-800">
  <% @songs.each do |song| %>
    <li class="px-4 py-4">
      <div class="flex items-start justify-between gap-3">
        <div class="min-w-0">
          <div class="font-medium truncate"><%= song.title %></div>
          <div class="text-sm text-gray-500 dark:text-gray-400"><%= song.subtitle %></div>
          <div class="mt-1 text-xs text-gray-400 dark:text-gray-500">
            <%= song.word_count %> words · <%= song.verb_count %> verbs (conjugated) · <%= song.sentence_count %> sentences
          </div>
        </div>
        <div class="flex shrink-0 flex-col items-end gap-2">
          <%= link_to song.listen_url, target: "_blank", rel: "noopener",
                class: "inline-flex items-center gap-1 rounded-lg border border-gray-200 px-3 py-1.5 text-sm font-medium text-gray-700 hover:bg-gray-50 dark:border-gray-700 dark:text-gray-200 dark:hover:bg-gray-900" do %>
            ▶︎ Listen
          <% end %>
          <% if (owned = @owned[song.listen_url]) %>
            <%= link_to "Drill →", play_path(deck: owned.slug, from: current_user.target_language, to: current_user.source_language),
                  class: "inline-flex items-center rounded-lg bg-gray-100 px-3 py-1.5 text-sm font-medium text-gray-600 dark:bg-gray-800 dark:text-gray-300" %>
          <% else %>
            <%= button_to add_song_path(slug: song.slug),
                  class: "inline-flex items-center rounded-lg bg-brand-indigo px-3 py-1.5 text-sm font-medium text-white hover:opacity-90" do %>
              + Add deck
            <% end %>
          <% end %>
        </div>
      </div>
    </li>
  <% end %>
</ul>

<p class="mt-4 text-center text-xs text-gray-400 dark:text-gray-500">
  Lyrics aren't reproduced here — tap Listen for the original. More songs coming.
</p>
