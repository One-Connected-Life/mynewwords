  "sentences": [
    {
      "nl": "Zij gelooft altijd in hem, ook als hij het zelf vergeet.",
      "en": "She always believes in him, even when he forgets it himself."
    },
    {
      "nl": "Hij zingt een lied voor zijn vrouw op een stille nacht.",
      "en": "He sings a song for his wife on a quiet night."
    },
    {
      "nl": "Ik voel een echte liefde in mijn hart.",
      "en": "I feel a real love in my heart."
    },
    {
      "nl": "Wij blijven samen, want we houden van elkaar.",
      "en": "We stay together, because we love each other."
    },
    {
      "nl": "Ze kijkt hem aan met lieve ogen en is blij.",
      "en": "She looks at him with kind eyes and is happy."
    },
    {
      "nl": "Hij droomt van een mooi leven met haar.",
      "en": "He dreams of a beautiful life with her."
    },
    {
      "nl": "Jij bent trouw en ik weet dat je altijd bij me blijft.",
      "en": "You are faithful and I know you will always stay with me."
    },
    {
      "nl": "Samen gaan zij de wereld in, gelukkig en niet alleen.",
      "en": "Together they go out into the world, happy and not alone."
    }
  ]
}
