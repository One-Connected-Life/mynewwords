  "sentences": [
    {
      "nl": "Vanavond kijk ik naar de sterren in de stille hemel.",
      "en": "Tonight I look at the stars in the quiet sky."
    },
    {
      "nl": "Wij lopen samen door de natte straten van de stad.",
      "en": "We walk together through the wet streets of the city."
    },
    {
      "nl": "Mijn hart voelt warm als jij naast mij staat.",
      "en": "My heart feels warm when you stand beside me."
    },
    {
      "nl": "Hij droomt elke nacht van een mooie, verre wereld.",
      "en": "He dreams every night of a beautiful, distant world."
    },
    {
      "nl": "Ik hou van de zachte regen op een koude avond.",
      "en": "I love the gentle rain on a cold evening."
    },
    {
      "nl": "Zij zingt zacht, en haar stem is heel mooi.",
      "en": "She sings softly, and her voice is very beautiful."
    },
    {
      "nl": "Wij wachten samen op het juiste moment.",
      "en": "We wait together for the right moment."
    },
    {
      "nl": "Ik wil dit gevoel nooit vergeten.",
      "en": "I never want to forget this feeling."
    }
  ]
}
